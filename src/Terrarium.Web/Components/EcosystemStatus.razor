@* EcosystemStatus — header bar with ecosystem metrics and play/pause state *@

<div class="ecosystem-status glass-panel">
    <div class="ecosystem-status__metric">
        <span class="glass-led @(IsRunning ? "glass-led--active" : "glass-led--idle")"></span>
        <span class="glass-label glass-label--nowrap">@(IsRunning ? "Running" : "Paused")</span>
    </div>
    <div class="ecosystem-status__metric">
        <span class="glass-led glass-led--idle"></span>
        <span class="glass-label glass-label--nowrap">Creatures: @CreatureCount</span>
    </div>
    <div class="ecosystem-status__metric">
        <span class="glass-led glass-led--waiting"></span>
        <span class="glass-label glass-label--nowrap">Tick: @TickCount</span>
    </div>
    <div class="ecosystem-status__metric">
        <span class="glass-led glass-led--idle"></span>
        <span class="glass-label glass-label--nowrap">Peers: @PeerCount</span>
    </div>
</div>

@code {
    [Parameter]
    public long TickCount { get; set; }

    [Parameter]
    public int CreatureCount { get; set; }

    [Parameter]
    public int PeerCount { get; set; }

    [Parameter]
    public bool IsRunning { get; set; }
}
