{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.38.33.27573",
      "templateHash": "2385682166206362365"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "The Azure region for all resources."
      }
    },
    "environmentName": {
      "type": "string",
      "metadata": {
        "description": "Unique suffix for resource names."
      }
    },
    "sqlAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "SQL Server administrator password."
      }
    },
    "sqlAdminLogin": {
      "type": "string",
      "defaultValue": "terrariumadmin",
      "metadata": {
        "description": "SQL Server administrator username."
      }
    },
    "serverImage": {
      "type": "string",
      "metadata": {
        "description": "Container image for Terrarium.Server."
      }
    },
    "webImage": {
      "type": "string",
      "metadata": {
        "description": "Container image for Terrarium.Web."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[format('log-{0}', parameters('environmentName'))]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[format('cae-{0}', parameters('environmentName'))]",
      "location": "[parameters('location')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', format('log-{0}', parameters('environmentName'))), '2023-09-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', format('log-{0}', parameters('environmentName'))), '2023-09-01').primarySharedKey]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', format('log-{0}', parameters('environmentName')))]"
      ]
    },
    {
      "type": "Microsoft.SignalRService/signalR",
      "apiVersion": "2024-03-01",
      "name": "[format('signalr-{0}', parameters('environmentName'))]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_S1",
        "tier": "Standard",
        "capacity": 1
      },
      "properties": {
        "features": [
          {
            "flag": "ServiceMode",
            "value": "Default"
          },
          {
            "flag": "EnableConnectivityLogs",
            "value": "true"
          }
        ],
        "cors": {
          "allowedOrigins": [
            "*"
          ]
        },
        "serverless": {
          "connectionTimeoutInSeconds": 60
        }
      }
    },
    {
      "type": "Microsoft.Sql/servers",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('sql-{0}', parameters('environmentName'))]",
      "location": "[parameters('location')]",
      "properties": {
        "administratorLogin": "[parameters('sqlAdminLogin')]",
        "administratorLoginPassword": "[parameters('sqlAdminPassword')]"
      }
    },
    {
      "type": "Microsoft.Sql/servers/databases",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/{1}', format('sql-{0}', parameters('environmentName')), 'Terrarium')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Basic",
        "tier": "Basic"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', format('sql-{0}', parameters('environmentName')))]"
      ]
    },
    {
      "type": "Microsoft.Sql/servers/firewallRules",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/{1}', format('sql-{0}', parameters('environmentName')), 'AllowAllAzureIps')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', format('sql-{0}', parameters('environmentName')))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[format('server-{0}', parameters('environmentName'))]",
      "location": "[parameters('location')]",
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', format('cae-{0}', parameters('environmentName')))]",
        "configuration": {
          "ingress": {
            "external": false,
            "targetPort": 8080,
            "transport": "http",
            "stickySessions": {
              "affinity": "sticky"
            }
          },
          "secrets": [
            {
              "name": "sql-connection",
              "value": "[format('Server=tcp:{0},1433;Database=Terrarium;User ID={1};Password={2};Encrypt=true;TrustServerCertificate=false;', reference(resourceId('Microsoft.Sql/servers', format('sql-{0}', parameters('environmentName'))), '2023-08-01-preview').fullyQualifiedDomainName, parameters('sqlAdminLogin'), parameters('sqlAdminPassword'))]"
            },
            {
              "name": "signalr-connection",
              "value": "[listKeys(resourceId('Microsoft.SignalRService/signalR', format('signalr-{0}', parameters('environmentName'))), '2024-03-01').primaryConnectionString]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "server",
              "image": "[parameters('serverImage')]",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              },
              "env": [
                {
                  "name": "ConnectionStrings__Terrarium",
                  "secretRef": "sql-connection"
                },
                {
                  "name": "ConnectionStrings__signalr",
                  "secretRef": "signalr-connection"
                }
              ],
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "path": "/alive",
                    "port": 8080,
                    "scheme": "HTTP"
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 30,
                  "timeoutSeconds": 5,
                  "failureThreshold": 3
                },
                {
                  "type": "Readiness",
                  "httpGet": {
                    "path": "/health",
                    "port": 8080,
                    "scheme": "HTTP"
                  },
                  "initialDelaySeconds": 5,
                  "periodSeconds": 10,
                  "timeoutSeconds": 5,
                  "failureThreshold": 3
                },
                {
                  "type": "Startup",
                  "httpGet": {
                    "path": "/alive",
                    "port": 8080,
                    "scheme": "HTTP"
                  },
                  "initialDelaySeconds": 0,
                  "periodSeconds": 5,
                  "timeoutSeconds": 5,
                  "failureThreshold": 30
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 10,
            "rules": [
              {
                "name": "cpu-scaling",
                "custom": {
                  "type": "cpu",
                  "metadata": {
                    "type": "Utilization",
                    "value": "70"
                  }
                }
              },
              {
                "name": "signalr-connection-scaling",
                "custom": {
                  "type": "azure-monitor",
                  "metadata": {
                    "metricName": "ConnectionCount",
                    "metricResourceUri": "[resourceId('Microsoft.SignalRService/signalR', format('signalr-{0}', parameters('environmentName')))]",
                    "targetValue": "100"
                  },
                  "auth": [
                    {
                      "secretRef": "signalr-connection",
                      "triggerParameter": "connectionFromEnv"
                    }
                  ]
                }
              }
            ]
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', format('cae-{0}', parameters('environmentName')))]",
        "[resourceId('Microsoft.SignalRService/signalR', format('signalr-{0}', parameters('environmentName')))]",
        "[resourceId('Microsoft.Sql/servers', format('sql-{0}', parameters('environmentName')))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[format('web-{0}', parameters('environmentName'))]",
      "location": "[parameters('location')]",
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', format('cae-{0}', parameters('environmentName')))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 8080,
            "transport": "http"
          }
        },
        "template": {
          "containers": [
            {
              "name": "web",
              "image": "[parameters('webImage')]",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              },
              "env": [
                {
                  "name": "services__server__https__0",
                  "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', format('server-{0}', parameters('environmentName'))), '2024-03-01').configuration.ingress.fqdn)]"
                }
              ],
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "path": "/alive",
                    "port": 8080,
                    "scheme": "HTTP"
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 30,
                  "timeoutSeconds": 5,
                  "failureThreshold": 3
                },
                {
                  "type": "Readiness",
                  "httpGet": {
                    "path": "/health",
                    "port": 8080,
                    "scheme": "HTTP"
                  },
                  "initialDelaySeconds": 5,
                  "periodSeconds": 10,
                  "timeoutSeconds": 5,
                  "failureThreshold": 3
                },
                {
                  "type": "Startup",
                  "httpGet": {
                    "path": "/alive",
                    "port": 8080,
                    "scheme": "HTTP"
                  },
                  "initialDelaySeconds": 0,
                  "periodSeconds": 5,
                  "timeoutSeconds": 5,
                  "failureThreshold": 30
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 5,
            "rules": [
              {
                "name": "http-scaling",
                "http": {
                  "metadata": {
                    "concurrentRequests": "50"
                  }
                }
              }
            ]
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', format('cae-{0}', parameters('environmentName')))]",
        "[resourceId('Microsoft.App/containerApps', format('server-{0}', parameters('environmentName')))]"
      ]
    }
  ],
  "outputs": {
    "webUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', format('web-{0}', parameters('environmentName'))), '2024-03-01').configuration.ingress.fqdn)]"
    },
    "serverUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', format('server-{0}', parameters('environmentName'))), '2024-03-01').configuration.ingress.fqdn)]"
    },
    "signalREndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.SignalRService/signalR', format('signalr-{0}', parameters('environmentName'))), '2024-03-01').hostName]"
    },
    "signalRResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.SignalRService/signalR', format('signalr-{0}', parameters('environmentName')))]"
    }
  }
}